{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/UserApi.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/UserApi.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/UserApi/UserApi.csproj"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "kill-5173",
      "type": "shell",
      "command": "fuser -k 5173/tcp || true",
      "presentation": {
        "reveal": "never"
      }
    },
    {
      "label": "kill-and-build",
      "dependsOrder": "sequence",
      "dependsOn": ["kill-5173", "build"],
      "problemMatcher": []
    }
  ]
}
