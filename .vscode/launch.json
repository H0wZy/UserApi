{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Watch Launch (Hot Reload)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "kill-and-build",
      "program": "dotnet",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/user-api.cs.csproj"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on: (https://\\S+)",
        "uriFormat": "%s/scalar"
      }
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
